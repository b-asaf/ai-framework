{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "instructions/SHARED.md"
  ],
  "model": "anthropic/claude-sonnet-4-5",
  "permission": {
    "bash": {
      "git status": "allow",
      "git log *": "allow",
      "git diff *": "allow",
      "git branch": "allow",
      "git branch *": "allow",
      "git checkout -b *": "deny",
      "git commit *": "deny",
      "git push *": "deny",
      "git merge *": "deny",
      "git rebase *": "deny",
      "git reset *": "deny",
      "git push --force *": "deny",
      "*": "ask"
    },
    "edit": "ask",
    "write": "allow"
  },
  "suggest": {
    "autofix": false
  }
}
