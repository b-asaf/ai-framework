#!/bin/sh
# commit-msg: enforce conventional commits format
COMMIT_MSG=$(cat "$1")
PATTERN="^(feat|fix|chore|refactor|docs|test|style|perf|ci|build|hotfix|release)(\(.+\))?: .{1,100}$"
if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
  echo ""
  echo "❌ ERROR: Commit message does not follow conventional commits format."
  echo "   Format: <type>(<scope>): <description>"
  echo "   Types: feat fix chore refactor docs test style perf ci hotfix release"
  echo "   Example: feat: add user export to CSV"
  echo "   Your message: $COMMIT_MSG"
  echo ""
  exit 1
fi
exit 0
